# Copy to .env for local development (never commit .env).

# --- Outbound email (magic links + admin “notify user” on accept/reject + compose email) ---
# Without RESEND_API_KEY or working SMTP, the API saves status but cannot send mail.
#
# Option A — Resend (https://resend.com): create an API key; set a verified “from” once you have a domain.
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM=CAL Notices <onboarding@resend.dev>
#
# Option B — Gmail (good for small teams): enable 2-Step Verification, then create an App Password
# (Google Account → Security → App passwords). Use smtp.gmail.com:587 and your Gmail as SMTP_USER.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASSWORD=xxxx xxxx xxxx xxxx
# SMTP_FROM=Your Org <you@gmail.com>
#
# Option C — Any SMTP (SendGrid, Mailgun, etc.)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.org

# Local/dev only: include sign-in/reset URLs in API JSON (only when FRONTEND_BASE_URL is localhost/127.0.0.1).
# On public production hosts (Vercel/Render/custom domains), these flags are ignored even if set.
# MAGIC_LINK_DEV_RETURN_TOKEN=true
# RESET_PASSWORD_DEV_RETURN_TOKEN=true
# RESET_PASSWORD_TTL_MINUTES=30

# Magic-link and password-reset links (must be the exact public URL of the SPA, no trailing slash).
# If this is wrong or points at an old host, emailed "Sign in" links will open the wrong site or an old deploy.
# For Vercel/frontend hosting, set FRONTEND_BASE_URL to your frontend URL, e.g.:
# FRONTEND_BASE_URL=https://your-app.vercel.app
# FRONTEND_BASE_URL=https://app.yourdomain.com
# Local Vite dev (default in repo frontend: same-origin API proxy, app at localhost:5173):
# FRONTEND_BASE_URL=http://localhost:5173

# --- Staff admin UI (frontend): open your deployed app URL with hash #/admin ---
# Example: https://your-app.vercel.app/#/admin
# Login uses ADMIN_EMAIL + ADMIN_PASSWORD (or hash) on the API server.
#
# Status emails and “Email user” from the admin portal use the same provider as magic links:
# set RESEND_API_KEY (+ RESEND_FROM) or SMTP_* (+ SMTP_FROM) above, or emails will not send.
